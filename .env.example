# LLM API Config
# Model Provider: tongyi (阿里云百炼), ollama (本地), openai, deepseek, wenxin
MODEL_PROVIDER=llama
MODEL_NAME=qwen-max

# Aliyun DashScope (阿里云百炼)
# Get your API key from: https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=your_dashscope_api_key
DASHSCOPE_MODEL_NAME=your_model_name

# Local Ollama
# Ensure Ollama is running and the model is pulled (e.g., `ollama pull qwen2.5`)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL_NAME=qwen3:8b
OLLAMA_EMBED_MODEL=all-minilm:22m

# OpenAI (Optional)
OPENAI_API_KEY=your_openai_api_key
OPENAI_API_BASE=https://api.openai.com/v1

# Baidu Wenxin (Optional)
QIANFAN_AK=your_qianfan_ak
QIANFAN_SK=your_qianfan_sk

# System Config
CHROMA_DB_PATH=./db
LOG_LEVEL=INFO
